# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ──────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-50-char-random-string
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use SQLite for local development
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Production (Neon PostgreSQL):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/splitwise?sslmode=require

# ── Redis (Django Channels channel layer) ────────────────────────────────────
# Leave blank in development — InMemoryChannelLayer is used automatically
REDIS_URL=

# Production (Upstash Redis):
# REDIS_URL=rediss://:password@lucky-wren-12345.upstash.io:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173 (Vite dev server)
# Production:  https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT Token Lifetimes ───────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
